# Fastify API
PORT=4000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5173

# MongoDB. If empty, the API uses temporary in-memory storage only for development.
MONGO_URI=mongodb://127.0.0.1:27017/votehub

# Security
SESSION_SECRET=replace-with-a-long-random-secret
ENCRYPTION_SECRET=replace-with-a-different-long-random-secret
OWNER_DISCORD_IDS=YOUR_DISCORD_ID,ANOTHER_ADMIN_ID
DISABLE_AUTH=false

# Discord OAuth2 application used for the dashboard login
DISCORD_CLIENT_ID=your-oauth-client-id
DISCORD_CLIENT_SECRET=your-oauth-client-secret
DISCORD_REDIRECT_URI=http://localhost:4000/api/auth/discord/callback

# Optional: a bot token used only for looking up bot username/avatar by bot ID
BOT_LOOKUP_TOKEN=
