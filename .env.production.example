# Production example for vote.tutorapide.xyz
PORT=4000
NODE_ENV=production
PUBLIC_BASE_URL=https://tdl.com
FRONTEND_URL=https://tdl.com
ALLOWED_ORIGINS=https://tdl.com

MONGO_URI=mongodb://127.0.0.1:27017/votehub

# Generate strong secrets, for example:
# openssl rand -base64 48
SESSION_SECRET=CHANGE_THIS_WITH_A_LONG_RANDOM_SECRET
ENCRYPTION_SECRET=CHANGE_THIS_WITH_A_DIFFERENT_LONG_RANDOM_SECRET
OWNER_DISCORD_IDS=YOUR_DISCORD_ID
DISABLE_AUTH=false

DISCORD_CLIENT_ID=your-oauth-client-id
DISCORD_CLIENT_SECRET=your-oauth-client-secret
DISCORD_REDIRECT_URI=https://tdl.com/api/auth/discord/callback
BOT_LOOKUP_TOKEN=
